{
  "name": "nyma",
  "version": "0.1.0",
  "description": "Nyma Yokai Mystic Agent — a minimal coding agent built with Squint + Bun + Vercel AI SDK + Ink",
  "type": "module",
  "bin": {
    "nyma": "./dist/agent/cli.mjs"
  },
  "scripts": {
    "dev": "concurrently \"npx squint watch\" \"bun --watch dist/agent/cli.mjs\"",
    "build": "npx squint compile",
    "bundle": "bun run build && bun build ./dist/agent/cli.mjs --compile --target=bun-darwin-arm64 --outfile=nyma",
    "bundle:linux-x64": "bun run build && bun build ./dist/agent/cli.mjs --compile --target=bun-linux-x64 --outfile=nyma-linux-x64",
    "bundle:linux-arm64": "bun run build && bun build ./dist/agent/cli.mjs --compile --target=bun-linux-arm64 --outfile=nyma-linux-arm64",
    "bundle:macos-x64": "bun run build && bun build ./dist/agent/cli.mjs --compile --target=bun-darwin-x64 --outfile=nyma-macos-x64",
    "bundle:windows": "bun run build && bun build ./dist/agent/cli.mjs --compile --target=bun-windows-x64 --outfile=nyma-windows-x64.exe",
    "prestart": "npx squint compile",
    "start": "bun dist/agent/cli.mjs",
    "pretest": "npx squint compile",
    "test": "bun test",
    "repl": "npx squint repl"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/openai": "^3.0.0",
    "ai": "^6.0.142",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "linkedom": "^0.18.12",
    "marked": "^17.0.6",
    "marked-terminal": "^7.3.0",
    "nanoid": "^5.0.0",
    "react": "^19.0.0",
    "shell-quote": "^1.8.1",
    "squint-cljs": "^0.10.186",
    "turndown": "^7.2.2",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "concurrently": "^9.0.0",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1"
  }
}
